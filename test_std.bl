// test_std.bl - Test complet de la standard library BackLang
// Usage: bl test_std.bl

print("=== Test Standard Library BackLang ===")
print("")

// Test std.math
print("--- std.math ---")
let x = 16
let racine = std.math.sqrt(x)
print("sqrt(16) = " + str(racine))

let y = -42
print("abs(-42) = " + str(std.math.abs(y)))

print("floor(3.7) = " + str(std.math.floor(3.7)))
print("ceil(3.2) = " + str(std.math.ceil(3.2)))
print("min(5, 10) = " + str(std.math.min(5, 10)))
print("max(5, 10) = " + str(std.math.max(5, 10)))
print("pow(2, 8) = " + str(std.math.pow(2, 8)))
print("")

// Test std.string
print("--- std.string ---")
let s = "  Hello World  "
print("trim: '" + std.string.trim(s) + "'")
print("toUpper: " + std.string.toUpper("hello"))
print("toLower: " + std.string.toLower("HELLO"))
print("split: " + str(std.string.split("a,b,c", ",")))
print("replace: " + std.string.replace("hello", "l", "w"))
print("startsWith: " + str(std.string.startsWith("hello", "he")))
print("endsWith: " + str(std.string.endsWith("hello", "lo")))
print("contains: " + str(std.string.contains("hello", "ell")))
print("")

// Test std.random
print("--- std.random ---")
print("rand: " + str(std.random.rand()))
print("randint(1, 100): " + str(std.random.randint(1, 100)))
let arr = [1, 2, 3, 4, 5]
print("choice: " + str(std.random.choice(arr)))
print("")

// Test std.os
print("--- std.os ---")
print("HOME: " + std.os.getenv("HOME"))
print("Args: " + str(std.os.args()))
print("")

// Test std.fs
print("--- std.fs ---")
let test_file = "/tmp/backlang_test.txt"
std.fs.writeFile(test_file, "Hello from BackLang!\n")
let content = std.fs.readFile(test_file)
print("readFile: " + content)
std.fs.appendFile(test_file, "Second line.\n")
print("after append: " + std.fs.readFile(test_file))
print("file exists: " + str(std.fs.exists(test_file)))
print("")

// Test type
print("--- type ---")
print("type(42): " + type(42))
print("type(\"hello\"): " + type("hello"))
print("type([1,2]): " + type([1, 2]))
print("type({a: 1}): " + type({a: 1}))
print("type(print): " + type(print))
print("")

print("=== Tous les tests sont terminés! ===")
