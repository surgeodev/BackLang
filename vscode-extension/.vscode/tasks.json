{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: install",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "problemMatcher": []
    },
    {
      "label": "npm: compile",
      "type": "shell",
      "command": "npm",
      "args": ["run", "compile"],
      "problemMatcher": [
        "$tsc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "npm: watch",
      "type": "shell",
      "command": "npm",
      "args": ["run", "watch"],
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": "$tsc",
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^.*",
            "endsPattern": "^.*"
          }
        }
      ]
    },
    {
      "label": "npm: lint",
      "type": "shell",
      "command": "npm",
      "args": ["run", "lint"],
      "problemMatcher": [
        "$eslint-compact"
      ]
    },
    {
      "label": "npm: test",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test"],
      "problemMatcher": []
    },
    {
      "label": "vsce: package",
      "type": "shell",
      "command": "vsce",
      "args": ["package"],
      "problemMatcher": []
    }
  ]
}
