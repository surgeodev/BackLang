{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "BackLang",
  "scopeName": "source.backlang",
  "fileTypes": ["bl"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#brackets"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.backlang",
          "match": "//.*$"
        },
        {
          "name": "comment.block.backlang",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.backlang",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.backlang",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.backlang",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.backlang",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.backlang",
          "match": "\\b(\\d+\\.?\\d*|\\d*\\.\\d+)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.backlang",
          "match": "\\b(if|else|while|for|break|continue|return|function|let|const)\\b"
        },
        {
          "name": "keyword.other.backlang",
          "match": "\\b(true|false|null|void|import|server|endpoint|middleware|type|cors|status|body)\\b"
        },
        {
          "name": "support.function.backlang",
          "match": "\\b(print|println|len|push|pop|shift|unshift|slice|splice|join|split|indexOf|includes|map|filter|reduce|forEach|sort|reverse|db\\.\\w+|db_open|db_query|db_execute)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.backlang",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.backlang",
          "match": "(\\+|-|\\*|/|%|==|!=|===|!==|<|>|<=|>=|&&|\\|\\||!|=|\\+=|-=|\\*=|/=)"
        }
      ]
    },
    "brackets": {
      "patterns": [
        {
          "name": "meta.brace.round.backlang",
          "match": "[()]"
        },
        {
          "name": "meta.brace.square.backlang",
          "match": "[\\[\\]]"
        },
        {
          "name": "meta.brace.curly.backlang",
          "match": "[{}]"
        }
      ]
    }
  }
}
